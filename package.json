{
  "name": "kcalorai",
  "version": "1.0.0",
  "description": "Edge-native calorie and macronutrient tracking application",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
